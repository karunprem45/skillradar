# Copy this file to .env and fill in your keys

# Database — defaults to SQLite at <repo>/data/skillradar.db (absolute path,
# resolved in src/db.py). Only set this to override, e.g. Postgres/Neon:
# DATABASE_URL=postgresql://user:pass@host/skillradar

# Adzuna (developer.adzuna.com — free tier, 250 calls/day). Optional:
# without these, ingestion uses the keyless sources (Remotive, Arbeitnow).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Anthropic API key — needed from Phase 2 (LLM skill extraction)
ANTHROPIC_API_KEY=
